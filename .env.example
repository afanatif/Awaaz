# .env.example — Awaz: Voice & Text Intelligence Pipeline
# Copy this file to .env and fill in all values before running.
# NEVER commit your real .env file — it is listed in .gitignore

# ── Google Gemini (required) ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Hugging Face (fallback LLM when Gemini quota is exhausted) ───────────────
HF_API_KEY=your-huggingface-api-key-here

# ── NewsAPI (required — free tier, 100 req/day) ─────────────────────────────
NEWSAPI_KEY=your-newsapi-key-here

# ── Reddit / PRAW (required for sentiment analysis) ─────────────────────────
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=awaz-intelligence-pipeline/1.0

# ── Exchange Rate API (required — free tier) ─────────────────────────────────
EXCHANGE_RATE_API_KEY=your-exchangerate-api-key-here

# ── Whisper Model (optional — defaults to base) ─────────────────────────────
# Options: tiny, base, small, medium (larger = more accurate but slower)
WHISPER_MODEL=base

# ── Slack Webhook (optional — for alert simulation) ──────────────────────────
SLACK_WEBHOOK_URL=

